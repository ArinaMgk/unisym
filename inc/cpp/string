	// Fixed-length string template, ideal for UTF-32 or pure ASCII
	template <typename CharT>
	class StringFixed {
		friend class String;
	protected:
		CharT* addr;
		stduint limits; // Capacity in terms of elements (CharT), including terminator
		stduint counts; // Effective count of elements
		bool allocated; // true if memory is managed by this object (heap)

	public:
		// Default Constructor
		StringFixed() : addr(nullptr), limits(0), counts(0), allocated(false) {}

		// Heap allocation constructor initialized with zero
		StringFixed(stduint buflen) {
			this->limits = buflen;
			this->counts = 0;
			this->allocated = true;
			// Assuming zalc allocates zeroed memory and takes bytes
			this->addr = (CharT*)zalc(buflen * sizeof(CharT));
		}

		// Buffer alias constructor (No heap allocation)
		StringFixed(CharT* buffer, stduint buffer_siz, stduint current_counts = 0) {
			this->addr = buffer;
			this->limits = buffer_siz;
			this->counts = current_counts;
			this->allocated = false;
		}

		// Move Constructor
		StringFixed(StringFixed&& str) noexcept {
			this->addr = str.addr;
			this->counts = str.counts;
			this->limits = str.limits;
			this->allocated = str.allocated;

			str.addr = nullptr;
			str.counts = 0;
			str.limits = 0;
			str.allocated = false;
		}

		// Move Assignment Operator
		StringFixed& operator=(StringFixed&& str) noexcept {
			if (this == &str) return *this;

			if (this->allocated && this->addr) {
				memf(this->addr);
			}

			this->addr = str.addr;
			this->counts = str.counts;
			this->limits = str.limits;
			this->allocated = str.allocated;

			str.addr = nullptr;
			str.counts = 0;
			str.limits = 0;
			str.allocated = false;

			return *this;
		}

		// Destructor
		~StringFixed() {
			if (allocated && addr) {
				memf(addr);
			}
			addr = nullptr;
			counts = 0;
			limits = 0;
			allocated = false;
		}

		// Copy Constructor
		StringFixed(const StringFixed& str) {
			this->counts = str.counts;
			this->limits = str.limits;
			this->allocated = str.allocated;
			if (str.allocated && str.addr) {
				this->addr = (CharT*)zalc(this->limits * sizeof(CharT));
				for (stduint i = 0; i < this->counts; ++i) {
					this->addr[i] = str.addr[i];
				}
			} else {
				this->addr = str.addr;
			}
		}

		// Copy Assignment Operator
		StringFixed& operator=(const StringFixed& str) {
			if (this == &str) return *this;

			if (this->allocated && this->addr) {
				memf(this->addr);
			}

			this->counts = str.counts;
			this->limits = str.limits;
			this->allocated = str.allocated;

			if (str.allocated && str.addr) {
				this->addr = (CharT*)zalc(this->limits * sizeof(CharT));
				for (stduint i = 0; i < this->counts; ++i) {
					this->addr[i] = str.addr[i];
				}
			} else {
				this->addr = str.addr;
			}
			return *this;
		}

		// O(1) Length retrieval. Since it is fixed length, counts == real character count
		stduint length() const {
			return counts;
		}

		// Raw pointer access
		const CharT* reference() const {
			return addr;
		}

		// O(1) Random Access Operator with negative index support
		// Completely safe because every element is exactly one character
		CharT& operator[] (stdsint idx) {
			stduint len = counts;
			if (!len || !addr) {
				static CharT dummy = 0;
				return dummy;
			}
			idx = idx % (stdsint)len;
			if (idx < 0) idx += len;
			return addr[idx];
		}

		const CharT& operator[] (stdsint idx) const {
			stduint len = counts;
			if (!len || !addr) {
				static const CharT dummy = 0;
				return dummy;
			}
			idx = idx % (stdsint)len;
			if (idx < 0) idx += len;
			return addr[idx];
		}
	};

	// Commonly used aliases
	using String8 = StringFixed<uint8_t>;  // Pure ASCII or raw bytes
	using String16 = StringFixed<uint16_t>; // UTF-16
	using String32 = StringFixed<char32_t>; // UTF-32 (The ultimate O(1) Unicode string)

