/* Interrupt Controllers
x86        PIC: Programmable Interrupt Controller
x64       APIC: Advanced Programmable Interrupt Controller
RISCV     PLIC: Platform-Level Interrupt Controller
CortexM   NVIC: Nested Vectored Interrupt Controller
CortexA    GIC: General Interrupt Controller
*/

#include "unisym"
#include "Device/Interrupt/interrupt_tab.h"

namespace uni {
	class RuptTrait {
	public:
		virtual void setInterrupt(Handler_t _func) const = 0;
		virtual void setInterruptPriority(byte preempt, byte sub_priority) const = 0;
		virtual void enInterrupt(bool enable = true) const = 0;
	#ifndef _MCCA
		virtual ~RuptTrait() = default; // avoid [-Wnon-virtual-dtor]
	#endif
		inline void enInterrupt(Handler_t _func) const {
			setInterrupt(_func);
			enInterrupt(true);
		}
	};
}

#define _COM_DEF_Interrupt_Interface() \
virtual void setInterrupt(Handler_t _func) const override;\
virtual void setInterruptPriority(byte preempt, byte sub_priority) const override;\
virtual void enInterrupt(bool enable = true) const override // you need add colon when using

#if defined(_MCCA)

namespace uni {
	class GateInterrupt
		#if (_MCCA & 0xFF00) == 0x8600
		: public gate_t
		#endif
	{
	public:
		
	};
	class InterruptControl {
	protected:
		// 0x400 at least.
		GateInterrupt* IVT_SEL_ADDR;
		#if (_MCCA & 0xFF00) == 0x8600
		byte typ = 0;// 0:PIC, 1:APIC, 2:x2APIC
		#endif
	public:// IOAPIC
		#if (_MCCA & 0xFF00) == 0x8600
		// RTE 64-bit
		void IO_Writ32(byte idx, uint32 val);
		uint32 IO_Read32(byte idx);
		inline void IO_Writ64(byte idx, uint64 val) {
			IO_Writ32(idx, val);
			IO_Writ32(idx + 1, val >> 32);
		}
		uint64 IO_Read64(byte idx) {
			uint64 ret = 0;
			ret = (uint64)IO_Read32(idx + 1) << 32;
			ret |= IO_Read32(idx);
			return ret;
		}
		auto getType() const { return typ; }

		// Read from Local APIC register
		uint32 ReadLAPIC(uint32 mmio_offset);
		// Write to Local APIC register
		void WriteLAPIC(uint32 mmio_offset, uint32 val);
		#endif
	public:
		// @param _ivt_sel_addr: linear address but physical
		InterruptControl(stduint _ivt_sel_addr) : IVT_SEL_ADDR((GateInterrupt*)_ivt_sel_addr) {}
		GateInterrupt& operator[](uint8 index) {
			return IVT_SEL_ADDR[index];
		}

		bool Initialize(byte typ);

		// Send End of Interrupt (EOI) to the active controller
		void SendEOI(byte irq = 0xFF);

		// enInterrupt but init the icontroller nor IC's cascade interrupt
		void enInterrupt(bool enable = true);

		// IF=0 -> Return false
		// IF=1 -> Return true after clear IF
		bool TryMaskInterrupt();

		// enAble: for IC self

		#if (_MCCA & 0xFF00) == 0x8600
		void Reset(word SegCode, stduint Offset = 0x00000000);
		#else
		void Reset();
		#endif

		#if (_MCCA & 0xFF00) == 0x1000
		static void setPriority(Request_t req, uint32 priority);
		static void setPriorityThreshold(uint32 core, uint32 threshold);
		static void setAble(Request_t req, bool ena = true);

		static Request_t getLastRequest();// of crt core
		static void setLastRequest(Request_t req);// of crt core
		#endif

		// inline stduint operator&() { return _IMM(IVT_SEL_ADDR); };

	};
}

