		// UTF-8 Character Iterator
		class Utf8Iterator {
		private:
			const char* ptr;
			const char* end;
			Rune current_rune;
			stduint current_bytes;

			// Decode the next UTF-8 sequence
			void decode() {
				if (ptr >= end) {
					current_rune = 0;
					current_bytes = 0;
					return;
				}

				unsigned char byte_val = static_cast<unsigned char>(*ptr);
				if (byte_val <= 0x7F) {
					current_rune = byte_val;
					current_bytes = 1;
				}
				else if ((byte_val & 0xE0) == 0xC0) {
					current_rune = byte_val & 0x1F;
					current_bytes = 2;
				}
				else if ((byte_val & 0xF0) == 0xE0) {
					current_rune = byte_val & 0x0F;
					current_bytes = 3;
				}
				else if ((byte_val & 0xF8) == 0xF0) {
					current_rune = byte_val & 0x07;
					current_bytes = 4;
				}
				else {
				// Invalid encoding, use Replacement Character
					current_rune = 0xFFFD;
					current_bytes = 1;
				}

				// Read continuation bytes safely
				for (stduint i = 1; i < current_bytes; ++i) {
					if (ptr + i >= end) {
						current_rune = 0xFFFD;
						current_bytes = i;
						break;
					}
					unsigned char next_val = static_cast<unsigned char>(ptr[i]);
					if ((next_val & 0xC0) != 0x80) {
						current_rune = 0xFFFD;
						current_bytes = i;
						break;
					}
					current_rune = (current_rune << 6) | (next_val & 0x3F);
				}
			}

		public:
			Utf8Iterator(const char* p, const char* e) : ptr(p), end(e) { decode(); }

			// Dereference returns the Unicode Code Point
			Rune operator*() const { return current_rune; }

			// Prefix increment
			Utf8Iterator& operator++() {
				ptr += current_bytes;
				decode();
				return *this;
			}

			// Comparison
			bool operator!=(const Utf8Iterator& other) const { return ptr != other.ptr; }
			bool operator==(const Utf8Iterator& other) const { return ptr == other.ptr; }
		};

		// Provide iteration methods (like Rust's .chars())
		Utf8Iterator chars_begin() const {
			return Utf8Iterator(addr, addr + counts);
		}
		Utf8Iterator chars_end() const {
			return Utf8Iterator(addr + counts, addr + counts);
		}
		struct CharsView {
			const String& str;
			Utf8Iterator begin() const { return str.chars_begin(); }
			Utf8Iterator end() const { return str.chars_end(); }
		};
